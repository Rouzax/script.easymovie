<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Poster Wall View
    Resolution: 1080i (1920x1080)

    Full-screen 6-column poster grid with bottom info overlay.
    No text on tiles — movie info appears in a gradient-fade overlay bar
    at the bottom when a poster is focused.

    Layout: 6 cols, poster 300x450 (2:3 ratio), cell 300x460
    Header: addon name (left) + buttons (right) + accent line
    Overlay: gradient fade + fanart thumb + title + metadata + plot

    Control IDs:
        655 - Panel control (poster grid)
        10  - Surprise Me button
        11  - Re-roll button
-->
<window>
    <defaultcontrol>655</defaultcontrol>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Full-screen dark background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D1117">common/white.png</texture>
        </control>

        <!-- Main content group -->
        <control type="group">
            <visible>Control.IsVisible(655)</visible>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- ==================== HEADER ==================== -->

            <!-- Addon name heading (left) -->
            <control type="label">
                <left>35</left>
                <top>10</top>
                <width>800</width>
                <height>40</height>
                <font>font14_title</font>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <label>$INFO[Window.Property(EasyMovie.AddonName)]</label>
            </control>

            <!-- Movie count -->
            <control type="label">
                <left>35</left>
                <top>18</top>
                <width>1400</width>
                <height>30</height>
                <align>right</align>
                <font>font10</font>
                <textcolor>FF888888</textcolor>
                <label>$INFO[Container(655).CurrentItem] / $INFO[Container(655).NumItems]</label>
            </control>

            <!-- Surprise Me Button (ID 10) — top-right -->
            <control type="button" id="10">
                <left>1475</left>
                <top>5</top>
                <width>200</width>
                <height>40</height>
                <align>center</align>
                <aligny>center</aligny>
                <font>font12</font>
                <textoffsetx>10</textoffsetx>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                <label>$ADDON[script.easymovie 32303]</label>
                <ondown>655</ondown>
                <onright>11</onright>
                <onleft>11</onleft>
                <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
            </control>

            <!-- Re-roll Button (ID 11) — top-right -->
            <control type="button" id="11">
                <left>1685</left>
                <top>5</top>
                <width>200</width>
                <height>40</height>
                <align>center</align>
                <aligny>center</aligny>
                <font>font12</font>
                <textoffsetx>10</textoffsetx>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                <label>$ADDON[script.easymovie 32304]</label>
                <ondown>655</ondown>
                <onright>10</onright>
                <onleft>10</onleft>
                <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>35</left>
                <top>48</top>
                <width>1850</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- ==================== POSTER GRID ==================== -->
            <control type="panel" id="655">
                <left>35</left>
                <top>56</top>
                <width>1850</width>
                <height>1024</height>
                <orientation>vertical</orientation>
                <onup>10</onup>
                <ondown>655</ondown>
                <onleft>655</onleft>
                <onright>655</onright>
                <preloaditems>6</preloaditems>
                <scrolltime tween="sine" easing="out">300</scrolltime>
                <itemgap>8</itemgap>

                <!-- Unfocused poster cell -->
                <itemlayout width="300" height="460">
                    <!-- Poster image (2:3 ratio) -->
                    <control type="image">
                        <left>0</left>
                        <top>5</top>
                        <width>300</width>
                        <height>450</height>
                        <aspectratio aligny="top">scale</aspectratio>
                        <texture background="true">$INFO[ListItem.Art(poster)]</texture>
                    </control>

                    <!-- Watched scrim (top-left gradient) -->
                    <control type="image">
                        <left>0</left>
                        <top>5</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topleft.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Watched icon -->
                    <control type="image">
                        <left>4</left>
                        <top>9</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/IconWatched.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Set scrim (top-right gradient) -->
                    <control type="image">
                        <left>220</left>
                        <top>5</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topright.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>

                    <!-- Set badge overlay -->
                    <control type="image">
                        <left>256</left>
                        <top>9</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/movieset.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>
                </itemlayout>

                <!-- Focused poster cell -->
                <focusedlayout width="300" height="460">
                    <!-- Accent border (3px around poster) -->
                    <control type="image">
                        <left>-3</left>
                        <top>2</top>
                        <width>306</width>
                        <height>456</height>
                        <texture border="3" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white.png</texture>
                    </control>

                    <!-- Poster image (2:3 ratio) -->
                    <control type="image">
                        <left>0</left>
                        <top>5</top>
                        <width>300</width>
                        <height>450</height>
                        <aspectratio aligny="top">scale</aspectratio>
                        <texture background="true">$INFO[ListItem.Art(poster)]</texture>
                    </control>

                    <!-- Watched scrim (top-left gradient) -->
                    <control type="image">
                        <left>0</left>
                        <top>5</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topleft.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Watched icon -->
                    <control type="image">
                        <left>4</left>
                        <top>9</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/IconWatched.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Set scrim (top-right gradient) -->
                    <control type="image">
                        <left>220</left>
                        <top>5</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topright.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>

                    <!-- Set badge overlay -->
                    <control type="image">
                        <left>256</left>
                        <top>9</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/movieset.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>
                </focusedlayout>
            </control>

            <!-- ==================== BOTTOM OVERLAY ==================== -->
            <control type="group">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>1080</height>

                <!-- Gradient fade (transparent → dark) -->
                <control type="image">
                    <left>0</left>
                    <top>880</top>
                    <width>1920</width>
                    <height>60</height>
                    <texture colordiffuse="FF0D1117">common/gradient_bottom.png</texture>
                </control>

                <!-- Solid dark bar -->
                <control type="image">
                    <left>0</left>
                    <top>940</top>
                    <width>1920</width>
                    <height>140</height>
                    <texture colordiffuse="FF0D1117">common/white.png</texture>
                </control>

                <!-- Accent line at top of overlay -->
                <control type="image">
                    <left>35</left>
                    <top>942</top>
                    <width>1850</width>
                    <height>1</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
                </control>

                <!-- Fanart thumbnail -->
                <control type="image">
                    <left>35</left>
                    <top>952</top>
                    <width>200</width>
                    <height>112</height>
                    <aspectratio>scale</aspectratio>
                    <texture background="true" fallback="">$INFO[Container(655).ListItem.Art(fanart)]</texture>
                </control>

                <!-- Movie Title -->
                <control type="label">
                    <left>255</left>
                    <top>948</top>
                    <width>700</width>
                    <height>30</height>
                    <font>font13</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Label]</label>
                </control>

                <!-- Year · MPAA · Rating · Runtime (when MPAA present) -->
                <control type="label">
                    <left>255</left>
                    <top>978</top>
                    <width>700</width>
                    <height>24</height>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  $INFO[Container(655).ListItem.Mpaa]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Property(runtime_min)]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Mpaa)</visible>
                </control>

                <!-- Year · Rating · Runtime (when no MPAA) -->
                <control type="label">
                    <left>255</left>
                    <top>978</top>
                    <width>700</width>
                    <height>24</height>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Property(runtime_min)]</label>
                    <visible>String.IsEmpty(Container(655).ListItem.Mpaa)</visible>
                </control>

                <!-- Genre · Set name -->
                <control type="label">
                    <left>255</left>
                    <top>1002</top>
                    <width>700</width>
                    <height>24</height>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Genre]</label>
                    <visible>String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Genre · Set name (when set present) -->
                <control type="label">
                    <left>255</left>
                    <top>1002</top>
                    <width>700</width>
                    <height>24</height>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Genre]  ·  [COLOR $INFO[Window.Property(EasyMovie.Accent)]]$INFO[Container(655).ListItem.Property(set_name)][/COLOR]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Plot (2-line excerpt, right side) -->
                <control type="textbox">
                    <left>980</left>
                    <top>952</top>
                    <width>905</width>
                    <height>112</height>
                    <font>font12</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Plot]</label>
                </control>
            </control>
        </control>
    </controls>
</window>
