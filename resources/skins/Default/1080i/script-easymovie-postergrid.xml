<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie PosterGrid View (Default)
    Resolution: 1080i (1920x1080)

    Full-screen window with:
    - Left: 4-column x 2-row poster grid (panel control)
    - Right: Info panel (fanart, metadata, plot)
    - Bottom: Re-roll and Surprise Me buttons

    Layout: 4 cols x 2 rows, poster 251x376 (2:3 ratio), cell 267x465

    Control IDs:
        655 - Panel control (poster grid)
        10  - Surprise Me button
        11  - Re-roll button
-->
<window>
    <defaultcontrol>10</defaultcontrol>

    <controls>
        <!-- Full-screen dark background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D1117">common/white.png</texture>
        </control>

        <!-- Window animations -->
        <control type="group">
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Addon name heading -->
            <control type="label">
                <left>30</left>
                <top>10</top>
                <width>1860</width>
                <height>40</height>
                <font>font14_title</font>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <label>$INFO[Window.Property(EasyMovie.AddonName)]</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>48</top>
                <width>1860</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- ====================================================== -->
            <!-- LEFT SIDE: Poster Grid (4 cols x 2 rows)               -->
            <!-- ====================================================== -->
            <control type="panel" id="655">
                <left>30</left>
                <top>60</top>
                <width>1100</width>
                <height>893</height>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">300</scrolltime>
                <onright>655</onright>
                <onleft>655</onleft>
                <ondown>10</ondown>
                <itemgap>10</itemgap>

                <!-- Unfocused poster cell -->
                <itemlayout width="250" height="441">
                    <!-- Poster image (2:3 ratio) -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>234</width>
                        <height>352</height>
                        <aspectratio aligny="top">scale</aspectratio>
                        <texture>$INFO[ListItem.Art(poster)]</texture>
                    </control>

                    <!-- Watched scrim (top-left gradient) -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topleft.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Watched icon -->
                    <control type="image">
                        <left>12</left>
                        <top>12</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/IconWatched.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Set scrim (top-right gradient) -->
                    <control type="image">
                        <left>162</left>
                        <top>8</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topright.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>

                    <!-- Set badge overlay -->
                    <control type="image">
                        <left>198</left>
                        <top>12</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/movieset.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>

                    <!-- Title -->
                    <control type="label">
                        <left>8</left>
                        <top>368</top>
                        <width>234</width>
                        <height>34</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <scroll>true</scroll>
                        <scrollspeed>30</scrollspeed>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Year · MPAA · Rating · Runtime (when MPAA present) -->
                    <control type="label">
                        <left>8</left>
                        <top>402</top>
                        <width>234</width>
                        <height>24</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>FF888888</textcolor>
                        <label>$INFO[ListItem.Year] · $INFO[ListItem.Mpaa] · ★$INFO[ListItem.Rating] · $INFO[ListItem.Property(runtime_min)]</label>
                        <visible>!String.IsEmpty(ListItem.Mpaa)</visible>
                    </control>

                    <!-- Year · Rating · Runtime (when no MPAA) -->
                    <control type="label">
                        <left>8</left>
                        <top>402</top>
                        <width>234</width>
                        <height>24</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>FF888888</textcolor>
                        <label>$INFO[ListItem.Year] · ★$INFO[ListItem.Rating] · $INFO[ListItem.Property(runtime_min)]</label>
                        <visible>String.IsEmpty(ListItem.Mpaa)</visible>
                    </control>
                </itemlayout>

                <!-- Focused poster cell -->
                <focusedlayout width="250" height="441">
                    <!-- Accent border (3px around poster) -->
                    <control type="image">
                        <left>5</left>
                        <top>5</top>
                        <width>240</width>
                        <height>358</height>
                        <texture border="3" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white.png</texture>
                    </control>

                    <!-- Poster image (2:3 ratio) -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>234</width>
                        <height>352</height>
                        <aspectratio aligny="top">scale</aspectratio>
                        <texture>$INFO[ListItem.Art(poster)]</texture>
                    </control>

                    <!-- Watched scrim (top-left gradient) -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topleft.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Watched icon -->
                    <control type="image">
                        <left>12</left>
                        <top>12</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/IconWatched.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(watched))</visible>
                    </control>

                    <!-- Set scrim (top-right gradient) -->
                    <control type="image">
                        <left>162</left>
                        <top>8</top>
                        <width>80</width>
                        <height>80</height>
                        <texture>common/scrim_topright.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>

                    <!-- Set badge overlay -->
                    <control type="image">
                        <left>198</left>
                        <top>12</top>
                        <width>40</width>
                        <height>40</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/movieset.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(set_name))</visible>
                    </control>

                    <!-- Title (accent color on focus) -->
                    <control type="label">
                        <left>8</left>
                        <top>368</top>
                        <width>234</width>
                        <height>34</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                        <scroll>true</scroll>
                        <scrollspeed>30</scrollspeed>
                        <label>$INFO[ListItem.Label]</label>
                    </control>

                    <!-- Year · MPAA · Rating · Runtime (when MPAA present) -->
                    <control type="label">
                        <left>8</left>
                        <top>402</top>
                        <width>234</width>
                        <height>24</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>$INFO[ListItem.Year] · $INFO[ListItem.Mpaa] · ★$INFO[ListItem.Rating] · $INFO[ListItem.Property(runtime_min)]</label>
                        <visible>!String.IsEmpty(ListItem.Mpaa)</visible>
                    </control>

                    <!-- Year · Rating · Runtime (when no MPAA) -->
                    <control type="label">
                        <left>8</left>
                        <top>402</top>
                        <width>234</width>
                        <height>24</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>ffFFFFFF</textcolor>
                        <label>$INFO[ListItem.Year] · ★$INFO[ListItem.Rating] · $INFO[ListItem.Property(runtime_min)]</label>
                        <visible>String.IsEmpty(ListItem.Mpaa)</visible>
                    </control>
                </focusedlayout>
            </control>

            <!-- ====================================================== -->
            <!-- RIGHT SIDE: Info Panel                                  -->
            <!-- ====================================================== -->
            <control type="group">
                <left>1170</left>
                <top>60</top>
                <width>720</width>
                <height>910</height>

                <!-- Fanart image (top aligned with poster grid) -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>720</width>
                    <height>405</height>
                    <aspectratio>scale</aspectratio>
                    <texture background="true" fallback="">$INFO[Container(655).ListItem.Art(fanart)]</texture>
                </control>

                <!-- Movie Title -->
                <control type="label">
                    <left>20</left>
                    <top>420</top>
                    <width>680</width>
                    <height>40</height>
                    <aligny>center</aligny>
                    <font>font13</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Label]</label>
                </control>

                <!-- Year · MPAA · Rating · Runtime (when MPAA present) -->
                <control type="label">
                    <left>20</left>
                    <top>462</top>
                    <width>680</width>
                    <height>28</height>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  $INFO[Container(655).ListItem.Mpaa]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Property(runtime_min)]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Mpaa)</visible>
                </control>

                <!-- Year · Rating · Runtime (when no MPAA) -->
                <control type="label">
                    <left>20</left>
                    <top>462</top>
                    <width>680</width>
                    <height>28</height>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Property(runtime_min)]</label>
                    <visible>String.IsEmpty(Container(655).ListItem.Mpaa)</visible>
                </control>

                <!-- Genre -->
                <control type="label">
                    <left>20</left>
                    <top>492</top>
                    <width>680</width>
                    <height>24</height>
                    <aligny>center</aligny>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Genre]</label>
                </control>

                <!-- Set info -->
                <control type="label">
                    <left>20</left>
                    <top>518</top>
                    <width>680</width>
                    <height>24</height>
                    <aligny>center</aligny>
                    <font>font10</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Property(set_name)]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Accent line -->
                <control type="image">
                    <left>20</left>
                    <top>550</top>
                    <width>680</width>
                    <height>2</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
                </control>

                <!-- Plot -->
                <control type="textbox">
                    <left>20</left>
                    <top>562</top>
                    <width>680</width>
                    <height>390</height>
                    <font>font12</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
                    <label>$INFO[Container(655).ListItem.Plot]</label>
                </control>
            </control>

            <!-- ====================================================== -->
            <!-- BOTTOM: Action Buttons                                  -->
            <!-- ====================================================== -->
            <control type="group">
                <left>30</left>
                <top>985</top>
                <width>1100</width>
                <height>50</height>

                <!-- Surprise Me Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <label>$ADDON[script.easymovie 32303]</label>
                    <onup>655</onup>
                    <onright>11</onright>
                    <onleft>11</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Re-roll Button (ID 11) -->
                <control type="button" id="11">
                    <left>230</left>
                    <top>0</top>
                    <width>200</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <label>$ADDON[script.easymovie 32304]</label>
                    <onup>655</onup>
                    <onright>10</onright>
                    <onleft>10</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>
        </control>
    </controls>
</window>
