<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Info Dialog (fullscreen)
    Resolution: 1080i (1920x1080)

    Control IDs:
        2   - Title label
        5   - Tagline label
        6   - Plot textbox
        10  - Play button
        20  - Poster image
        40  - Fanart background image
        100 - Cast strip list (display-only)
        500 - Metadata list (display-only, label:value)
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol always="true">10</defaultcontrol>
    <controls>
        <!-- Opaque black base: browse window never shows through (fanart may be empty) -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="FF000000">common/white.png</texture>
        </control>
        <!-- Fanart background, above the black base -->
        <control type="image" id="40">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <aspectratio>scale</aspectratio>
            <texture background="true">-</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
        </control>
        <!-- Dim over fanart for readability (fanart stays a faint ambient wash) -->
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="E6000000">common/white.png</texture>
        </control>

        <!-- Foreground content: animates in/out with the dialog -->
        <control type="group">
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="96" end="100" center="960,540" time="300" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="96" center="960,540" time="200" tween="sine" easing="out" />
                <effect type="fade" start="100" end="0" time="200" tween="cubic" easing="out" />
            </animation>

        <!-- Poster with accent border -->
        <control type="group">
            <left>80</left><top>165</top>
            <control type="image">
                <left>-3</left><top>-3</top><width>406</width><height>606</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white.png</texture>
            </control>
            <control type="image" id="20">
                <left>0</left><top>0</top><width>400</width><height>600</height>
                <aspectratio>scale</aspectratio>
                <texture background="true">-</texture>
            </control>
        </control>

        <!-- Title (full-width header, aligned to the poster's left edge) -->
        <control type="label" id="2">
            <left>80</left><top>36</top><width>1760</width><height>56</height>
            <font>font36_title</font>
            <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
            <label>-</label>
        </control>
        <!-- Tagline -->
        <control type="label" id="5">
            <left>80</left><top>96</top><width>1760</width><height>28</height>
            <font>font10</font>
            <textcolor>FFAAAAAA</textcolor>
            <label></label>
        </control>
        <!-- Accent separator under the header (full width) -->
        <control type="image">
            <left>80</left><top>130</top><width>1760</width><height>2</height>
            <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
        </control>

        <!-- Cast strip: wider portrait tiles, scrollable (Up from Play focuses it) -->
        <control type="list" id="100">
            <left>560</left><top>162</top><width>1280</width><height>288</height>
            <orientation>horizontal</orientation>
            <itemgap>16</itemgap>
            <onup>10</onup>
            <ondown>10</ondown>
            <itemlayout width="200" height="288">
                <!-- placeholder box (shows when a cast member has no thumbnail);
                     thumb inset 3px from the item top so the focused accent frame
                     (top 0) has headroom and its top edge is not clipped by the list -->
                <control type="image">
                    <left>30</left><top>3</top><width>140</width><height>210</height>
                    <texture colordiffuse="1fFFFFFF">common/white.png</texture>
                </control>
                <control type="image">
                    <left>30</left><top>3</top><width>140</width><height>210</height>
                    <aspectratio>keep</aspectratio>
                    <texture background="true">$INFO[ListItem.Art(thumb)]</texture>
                </control>
                <control type="label">
                    <left>0</left><top>217</top><width>200</width><height>36</height>
                    <font>font10</font><align>center</align>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>0</left><top>253</top><width>200</width><height>32</height>
                    <font>font10</font><align>center</align>
                    <textcolor>FF888888</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
            </itemlayout>
            <focusedlayout width="200" height="288">
                <control type="image">
                    <left>27</left><top>0</top><width>146</width><height>216</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white.png</texture>
                </control>
                <control type="image">
                    <left>30</left><top>3</top><width>140</width><height>210</height>
                    <aspectratio>keep</aspectratio>
                    <texture background="true">$INFO[ListItem.Art(thumb)]</texture>
                </control>
                <control type="label">
                    <left>0</left><top>217</top><width>200</width><height>36</height>
                    <font>font10</font><align>center</align>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>0</left><top>253</top><width>200</width><height>32</height>
                    <font>font10</font><align>center</align>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
            </focusedlayout>
        </control>

        <!-- Plot -->
        <control type="textbox" id="6">
            <left>560</left><top>470</top><width>760</width><height>390</height>
            <font>font12</font>
            <textcolor>FFCCCCCC</textcolor>
            <autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
        </control>

        <!-- Metadata column (display-only label:value list) -->
        <control type="list" id="500">
            <left>1360</left><top>470</top><width>480</width><height>390</height>
            <orientation>vertical</orientation>
            <itemgap>6</itemgap>
            <!-- display-only: enable=false removes it from focus navigation (CanFocus); it still renders -->
            <enable>false</enable>
            <itemlayout width="480" height="40">
                <control type="label">
                    <left>0</left><top>0</top><width>115</width><height>40</height>
                    <font>font10</font><aligny>center</aligny>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <left>120</left><top>0</top><width>360</width><height>40</height>
                    <font>font10</font><aligny>center</aligny>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                </control>
            </itemlayout>
            <focusedlayout width="480" height="40" />
        </control>

        <!-- Button row (Play only, centered on screen) -->
        <control type="grouplist">
            <left>80</left><top>980</top><width>1760</width><height>50</height>
            <itemgap>30</itemgap>
            <align>center</align>
            <orientation>horizontal</orientation>
            <control type="button" id="10">
                <onup>100</onup>
                <width>200</width><height>50</height>
                <align>center</align><aligny>center</aligny>
                <font>font12</font><textoffsetx>10</textoffsetx>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
            </control>
        </control>
        </control>
    </controls>
</window>
