<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Posters View
    Resolution: 1080i (1920x1080)

    Layout: Left info panel (fanart, title, metadata, plot) + Right poster grid

    Control IDs:
        655 - Main poster panel container
        10  - Surprise Me button
        11  - Re-roll button
-->
<window>
    <visible>!System.ScreenSaverActive</visible>

    <controls>
        <!-- Full screen background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D1117">common/white.png</texture>
        </control>

        <!-- Main content group -->
        <control type="group">
            <visible>Control.IsVisible(655)</visible>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="sine" easing="in" />
                <effect type="zoom" start="85" end="100" time="300" center="auto" tween="sine" easing="out" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="85" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- ==================== LEFT SIDE: INFO PANEL ==================== -->
            <control type="group">
                <left>40</left>
                <top>60</top>
                <width>660</width>
                <height>960</height>

                <!-- Fanart preview -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>620</width>
                    <height>349</height>
                    <texture background="true" fallback="">$INFO[Container(655).ListItem.Art(fanart)]</texture>
                    <aspectratio aligny="top">scale</aspectratio>
                </control>

                <!-- Separator line -->
                <control type="image">
                    <left>0</left>
                    <top>357</top>
                    <width>620</width>
                    <height>2</height>
                    <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
                </control>

                <!-- Movie Title -->
                <control type="label">
                    <left>0</left>
                    <top>369</top>
                    <width>620</width>
                    <height>45</height>
                    <font>font13</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Label]</label>
                </control>

                <!-- Year · Rating · Runtime -->
                <control type="label">
                    <left>0</left>
                    <top>419</top>
                    <width>620</width>
                    <height>30</height>
                    <font>font12</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <label>$INFO[Container(655).ListItem.Year]  ·  ★ $INFO[Container(655).ListItem.Rating]  ·  $INFO[Container(655).ListItem.Duration]m</label>
                </control>

                <!-- Genre -->
                <control type="label">
                    <left>0</left>
                    <top>454</top>
                    <width>620</width>
                    <height>25</height>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <label>$INFO[Container(655).ListItem.Genre]</label>
                </control>

                <!-- Set info -->
                <control type="label">
                    <left>0</left>
                    <top>482</top>
                    <width>620</width>
                    <height>25</height>
                    <font>font10</font>
                    <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                    <label>$INFO[Container(655).ListItem.Property(set_name)]</label>
                    <visible>!String.IsEmpty(Container(655).ListItem.Property(set_name))</visible>
                </control>

                <!-- Plot -->
                <control type="textbox">
                    <left>0</left>
                    <top>520</top>
                    <width>620</width>
                    <height>380</height>
                    <font>font12</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <autoscroll delay="6000" time="3000" repeat="10000">true</autoscroll>
                    <label>$INFO[Container(655).ListItem.Plot]</label>
                </control>

                <!-- Buttons -->
                <control type="group">
                    <left>0</left>
                    <top>910</top>
                    <width>620</width>
                    <height>50</height>

                    <control type="button" id="10">
                        <left>0</left>
                        <top>0</top>
                        <width>200</width>
                        <height>50</height>
                        <align>center</align>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textoffsetx>10</textoffsetx>
                        <textcolor>FFFFFFFF</textcolor>
                        <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                        <label>$ADDON[script.easymovie 32303]</label>
                        <onup>655</onup>
                        <onright>11</onright>
                        <onleft>11</onleft>
                        <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                        <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                    </control>

                    <control type="button" id="11">
                        <left>230</left>
                        <top>0</top>
                        <width>200</width>
                        <height>50</height>
                        <align>center</align>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textoffsetx>10</textoffsetx>
                        <textcolor>FFFFFFFF</textcolor>
                        <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                        <label>$ADDON[script.easymovie 32304]</label>
                        <onup>655</onup>
                        <onright>10</onright>
                        <onleft>10</onleft>
                        <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                        <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                    </control>
                </control>
            </control>

            <!-- ==================== RIGHT SIDE: POSTER GRID ==================== -->
            <control type="panel" id="655">
                <left>740</left>
                <top>60</top>
                <width>1140</width>
                <height>960</height>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">300</scrolltime>
                <onleft>10</onleft>
                <onright>655</onright>
                <ondown>655</ondown>
                <itemgap>8</itemgap>

                <!-- Unfocused poster -->
                <itemlayout width="220" height="340">
                    <control type="image">
                        <left>5</left>
                        <top>5</top>
                        <width>210</width>
                        <height>315</height>
                        <aspectratio>scale</aspectratio>
                        <texture>$INFO[ListItem.Art(poster)]</texture>
                    </control>
                    <control type="label">
                        <left>5</left>
                        <top>318</top>
                        <width>210</width>
                        <height>20</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>FFAAAAAA</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </itemlayout>

                <!-- Focused poster -->
                <focusedlayout width="220" height="340">
                    <!-- Accent border -->
                    <control type="image">
                        <left>2</left>
                        <top>2</top>
                        <width>216</width>
                        <height>321</height>
                        <texture border="4" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white_rounded.png</texture>
                    </control>
                    <control type="image">
                        <left>5</left>
                        <top>5</top>
                        <width>210</width>
                        <height>315</height>
                        <aspectratio>scale</aspectratio>
                        <texture>$INFO[ListItem.Art(poster)]</texture>
                    </control>
                    <control type="label">
                        <left>5</left>
                        <top>318</top>
                        <width>210</width>
                        <height>20</height>
                        <aligny>center</aligny>
                        <font>font10</font>
                        <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </focusedlayout>
            </control>
        </control>
    </controls>
</window>
