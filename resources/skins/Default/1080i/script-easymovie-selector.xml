<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyMovie Settings Selector Dialog
    Resolution: 1080i (1920x1080)

    Used by selector.py for genre and MPAA rating selection from settings.
    Similar to the wizard select dialog but with Enable All / Ignore All buttons.

    Control IDs:
        1   - Heading label
        100 - Scrollable list (checkbox items)
        10  - Save button
        11  - Cancel button
        12  - Enable All button
        13  - Ignore All button
-->
<window>
    <zorder>1</zorder>
    <defaultcontrol always="true">100</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 700x700 centered -->
        <control type="group">
            <left>610</left>
            <top>190</top>
            <width>700</width>
            <height>700</height>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" delay="100" />
                <effect type="slide" start="0,-100" end="0" center="auto" tween="back" easing="out" time="600" delay="100" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="zoom" start="100" end="95" center="auto" tween="sine" easing="out" time="300" />
                <effect type="fade" start="100" end="0" tween="cubic" easing="out" time="300" />
            </animation>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>704</width>
                <height>704</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>700</width>
                <height>700</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) -->
            <control type="label" id="1">
                <left>30</left>
                <top>13</top>
                <width>640</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator -->
            <control type="image">
                <left>30</left>
                <top>66</top>
                <width>640</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Scrollable list with checkboxes (ID 100) -->
            <control type="list" id="100">
                <left>30</left>
                <top>82</top>
                <width>640</width>
                <height>490</height>
                <orientation>vertical</orientation>
                <scrolltime tween="sine" easing="out">200</scrolltime>
                <onleft>100</onleft>
                <onright>100</onright>
                <onup>100</onup>
                <ondown>12</ondown>

                <!-- Unfocused item -->
                <itemlayout width="640" height="50">
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="44FFFFFF">check_off.png</texture>
                        <visible>!String.IsEqual(ListItem.Property(checked),true)</visible>
                    </control>
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">check_on.png</texture>
                        <visible>String.IsEqual(ListItem.Property(checked),true)</visible>
                    </control>
                    <control type="label">
                        <left>48</left>
                        <top>0</top>
                        <width>580</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>FFCCCCCC</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </itemlayout>

                <!-- Focused item -->
                <focusedlayout width="640" height="50">
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>640</width>
                        <height>50</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.AccentBG)]">common/white.png</texture>
                    </control>
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="66FFFFFF">check_off.png</texture>
                        <visible>!String.IsEqual(ListItem.Property(checked),true)</visible>
                    </control>
                    <control type="image">
                        <left>10</left>
                        <top>13</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="$INFO[Window.Property(EasyMovie.Accent)]">check_on.png</texture>
                        <visible>String.IsEqual(ListItem.Property(checked),true)</visible>
                    </control>
                    <control type="label">
                        <left>48</left>
                        <top>0</top>
                        <width>580</width>
                        <height>50</height>
                        <aligny>center</aligny>
                        <font>font12</font>
                        <textcolor>$INFO[Window.Property(EasyMovie.Accent)]</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </focusedlayout>
            </control>

            <!-- Button Row -->
            <control type="group">
                <left>30</left>
                <top>586</top>
                <width>640</width>
                <height>50</height>

                <!-- Enable All (ID 12) -->
                <control type="button" id="12">
                    <left>0</left>
                    <top>0</top>
                    <width>150</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <label>$ADDON[script.easymovie 32309]</label>
                    <onup>100</onup>
                    <onright>13</onright>
                    <ondown>11</ondown>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Ignore All (ID 13) -->
                <control type="button" id="13">
                    <left>165</left>
                    <top>0</top>
                    <width>150</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <label>$ADDON[script.easymovie 32310]</label>
                    <onup>100</onup>
                    <onleft>12</onleft>
                    <onright>11</onright>
                    <ondown>11</ondown>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>

            <!-- Save/Cancel Row -->
            <control type="group">
                <left>30</left>
                <top>640</top>
                <width>640</width>
                <height>50</height>

                <!-- Cancel (ID 11) -->
                <control type="button" id="11">
                    <left>325</left>
                    <top>0</top>
                    <width>150</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <label>$ADDON[script.easymovie 32301]</label>
                    <onup>12</onup>
                    <onright>10</onright>
                    <onleft>10</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- Save (ID 10) -->
                <control type="button" id="10">
                    <left>490</left>
                    <top>0</top>
                    <width>150</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyMovie.ButtonTextFocused)]</focusedcolor>
                    <label>$ADDON[script.easymovie 32308]</label>
                    <onup>13</onup>
                    <onright>11</onright>
                    <onleft>11</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyMovie.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>
        </control>
    </controls>
</window>
